# =============================================================
#  Supabase
# =============================================================
# Settings → API en tu proyecto de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Clave de servicio (service_role / "sb_secret_..." en el nuevo formato).
# SOLO se usa en el servidor. NUNCA la expongas en el cliente ni con
# prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================
#  App
# =============================================================
# URL pública de la app, CON protocolo y sin slash final.
# En local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Contraseña del panel /admin (MVP). En producción migra a Supabase Auth
# (módulo B3) con roles por negocio.
ADMIN_PASSWORD=cambia-esta-clave

# =============================================================
#  Apple Wallet (opcional)
# =============================================================
# Requiere una cuenta de Apple Developer ($99/año).
APPLE_PASS_TYPE_IDENTIFIER=pass.com.tudominio.loyalty
APPLE_TEAM_IDENTIFIER=ABCDE12345
APPLE_PASS_ORG_NAME=Mi Negocio

# Certificados en formato PEM, codificados en base64 (ver README).
APPLE_WWDR_BASE64=
APPLE_SIGNER_CERT_BASE64=
APPLE_SIGNER_KEY_BASE64=
APPLE_SIGNER_KEY_PASSPHRASE=

# =============================================================
#  Google Wallet (opcional, módulo B12 — aún no implementado)
# =============================================================
# Cuenta de Issuer en https://pay.google.com/business/console
# + Service Account de Google Cloud con la Wallet API habilitada.
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON_BASE64=
